# API base URL — Vite dev server proxies /api/* to the PHP backend (XAMPP)
# In development this stays as /api (proxied by vite.config.js)
# For production, set this to the full backend URL e.g. https://yourdomain.com/Backend
VITE_API_BASE_URL=http://localhost/eyeshi_gabcha/Backend

# Base URL for uploaded files served by the backend
# In development this is proxied by vite.config.js (/uploads → /Backend/uploads)
VITE_UPLOADS_BASE_URL=/uploads
